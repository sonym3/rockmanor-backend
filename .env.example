# ── Server ────────────────────────────────────────────────────────────────
PORT=3001

# Public site URL (used for CORS). Local: http://localhost:5173
CLIENT_URL=https://3stepscleaning.ca

# ── Email (Resend) ──────────────────────────────────────────────────────────
# Get this from https://resend.com → API Keys. Never commit the real value.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Verified sender on your Resend domain (must match a domain verified in Resend).
MAIL_FROM=3 Steps Cleaning <bookings@3stepscleaning.ca>

# Where booking + feedback notifications are sent (the owner's inbox).
BOOKING_RECIPIENT=book3steps@gmail.com

# Reply-to address shown on customer confirmation emails.
# Set up in Cloudflare Email Routing to forward to BOOKING_RECIPIENT.
REPLY_TO=hello@3stepscleaning.ca

# ── Bot protection (Cloudflare Turnstile) ───────────────────────────────────
# Secret key from Cloudflare dashboard → Turnstile. Leave blank to disable.
TURNSTILE_SECRET=0x4xxxxxxxxxxxxxxxxxxxxxxxxx
